# Invoice server environment template
# Copy values into your shell or a local .env loader before starting server.py

# LLM backend used by /parse and exposed via /config
LLM_ENDPOINT=http://localhost:3030/v1/chat/completions
LLM_MODEL=claude-sonnet-4.6
LLM_TIMEOUT=300

# Ensure LLM/OpenRouter endpoint is reachable before each parse request.
# Recommended true for local reliability.
LLM_PRECHECK=true

# TCP connectivity timeout in seconds for the precheck.
LLM_PRECHECK_TIMEOUT=1.5

# Comma-separated allowed origins for browser access to this API.
# Examples:
#   CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500
#   CORS_ORIGINS=http://localhost:5173
# If unset, server.py defaults to localhost + file-origin safe local values.
CORS_ORIGINS=

# Include exception stack traces in API error payloads (dev only).
# true | false
INCLUDE_ERROR_TRACE=false
